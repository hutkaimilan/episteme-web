# EPISTEME — environment variables
# Copy to .env.local for local development; set in Vercel project settings for production.

# REQUIRED, server-side only. Used exclusively by the AI receptionist route
# (src/app/api/chat/route.ts). Never expose this to the client.
# Get a free-tier key from the Groq Console (https://console.groq.com) —
# no card required, no EU restriction; the route calls the
# llama-3.3-70b-versatile model via Groq's OpenAI-compatible API.
GROQ_API_KEY=

# REQUIRED for the Retell AI voice agent's booking functions endpoint
# (/api/retell/functions). Any long random string; the same value goes into
# the function URL (?secret=...) or x-retell-secret header configured in the
# Retell dashboard. See RETELL_SETUP.md.
RETELL_FUNCTION_SECRET=

# REQUIRED for the demo/admin reset endpoint (/api/admin/reset). Any long
# random string; present it via the x-admin-secret header (POST to reset) or
# ?secret=... query (GET for the occupancy snapshot). Without it the endpoint
# refuses to run (503) — a booking-mutating endpoint is never silently open.
ADMIN_RESET_SECRET=

# Vercel KV (Redis) — booking storage. When BOTH are set, reservations persist
# in KV, shared across all serverless instances; without them the app falls
# back to per-process in-memory storage (fine for local dev / CI, NOT for
# production). Create a KV/Redis store in the Vercel dashboard (Storage tab) and
# "Connect" it to the project — Vercel injects these automatically on deploy.
# For local use, run `vercel env pull .env.local` after connecting.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Leonardo AI Production API key — get from app.leonardo.ai API section.
# Put the real value in .env.local, never commit it. Used only by
# scripts/generate-menu-images.js (menu image regeneration), not by the app.
LEONARDO_API_KEY=

# NOTE: the EmailJS credentials (service ID, template ID, public key) are
# currently client-side constants in src/components/ReservationSection.tsx —
# this matches the existing external EmailJS setup, and EmailJS public keys
# are designed to be exposed in the browser. Moving them to NEXT_PUBLIC_*
# env vars is a reasonable future improvement, but not required.
